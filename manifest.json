{
  "schemaVersion": "app.0.1",
  "id": "com.haas.transcode-engine",
  "name": "Transcode Engine",
  "description": "ffmpeg-backed batch transcoder with VAAPI/VideoToolbox hardware acceleration and an HTTP/SSE control API, for other Hosty apps to drive re-encoding jobs over a dependency.",
  "version": "0.4.1",
  "source": {
    "type": "git",
    "repository": "https://github.com/alex-de-haas/transcode-engine.git",
    "branch": "main"
  },
  "runtimeProfiles": [
    { "key": "docker", "type": "docker", "default": true },
    { "key": "docker-vaapi", "type": "docker" },
    { "key": "local", "type": "localCommand" }
  ],
  "defaultRuntime": "docker",
  "services": [
    {
      "key": "engine",
      "runtimes": {
        "docker": {
          "type": "docker",
          "image": { "repository": "ghcr.io/alex-de-haas/transcode-engine", "tag": "latest" },
          "ports": [
            { "key": "control", "containerPort": 8080, "protocol": "http" }
          ]
        },
        "docker-vaapi": {
          "type": "docker",
          "image": { "repository": "ghcr.io/alex-de-haas/transcode-engine", "tag": "latest" },
          "devices": ["/dev/dri"],
          "ports": [
            { "key": "control", "containerPort": 8080, "protocol": "http" }
          ]
        },
        "local": {
          "type": "localCommand",
          "workingDirectory": ".",
          "command": "dotnet run --project src/TranscodeEngine.Api --configuration Release",
          "ports": [
            { "key": "control", "containerPort": 8080, "protocol": "http" }
          ]
        }
      }
    }
  ],
  "endpoints": [
    { "key": "control", "service": "engine", "port": "control", "protocol": "http" }
  ],
  "data": {
    "enabled": true,
    "targets": [
      { "runtime": "docker", "service": "engine", "containerPath": "/app/data", "environment": "HOSTY_APP_DATA_DIR" },
      { "runtime": "local", "environment": "HOSTY_APP_DATA_DIR" }
    ]
  },
  "externalMounts": {
    "media": { "kind": "host-path", "multiple": true, "mode": "rw", "service": "engine", "required": true }
  },
  "settings": [
    { "key": "HWACCEL", "type": "string", "default": "auto", "label": "Hardware acceleration", "description": "Default hardware acceleration when a job doesn't request one. auto picks VideoToolbox (macOS), AMF (Windows + AMD), VAAPI (Linux render device present), else software. Explicit values: vaapi, videotoolbox, amf, none." },
    { "key": "VAAPI_DEVICE", "type": "string", "default": "/dev/dri/renderD128", "label": "VAAPI render node", "description": "Render node passed to ffmpeg's -vaapi_device and used by the hardware probe. Only relevant for VAAPI on Linux." },
    { "key": "MAX_CONCURRENT_JOBS", "type": "number", "default": "1", "label": "Max concurrent jobs", "description": "How many transcode jobs run at once. Defaults to 1 — hardware encoders have limited sessions. Floored at 1." }
  ],
  "telemetry": { "enabled": true, "sampleRatio": 0.1 },
  "capabilities": ["backup", "logs"],
  "catalogMetadata": {
    "publisher": {
      "name": "Haas",
      "url": "https://github.com/alex-de-haas",
      "email": "a.zayats@outlook.com"
    },
    "category": "Media",
    "tags": ["transcode", "ffmpeg", "video", "hardware-acceleration", "engine"],
    "icon": "assets/icon.svg",
    "license": "AGPL-3.0-only",
    "links": {
      "website": "https://github.com/alex-de-haas/transcode-engine",
      "docs": "https://github.com/alex-de-haas/transcode-engine/blob/main/docs/root.md"
    },
    "summary": "ffmpeg-backed batch transcoder with hardware acceleration and an HTTP/SSE control API.",
    "descriptionFile": "docs/store.md"
  }
}
